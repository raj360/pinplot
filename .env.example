# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Primary DB: Supabase Postgres (use for dev, staging, and production)
# Dashboard → Settings → Database → Connection string (URI, direct)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: local PostGIS for offline dev only (docker compose)
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5433/plotpin

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ─── Google Maps ────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
NEXT_PUBLIC_GOOGLE_MAP_ID=your-map-id

# ─── Payments ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...

# ─── Pricing (UGX defaults) ─────────────────────────────────
TENANT_UNLOCK_FEE_UGX=20000
LANDLORD_LISTING_FEE_UGX=30000

# ─── Dev Verification  Code (optional)───────────────────────────────────────────────
AUTH_OTP_DEV_CODE=999999

# ─── Postmark ───────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=your-server-token
POSTMARK_FROM_EMAIL=noreply@yourdomain.com
