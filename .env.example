# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App runtime — transaction pooler (port 6543). Dashboard → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations only — session pooler (port 5432). Do NOT use db.*.supabase.co:5432 for the Nest API.
DIRECT_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# Optional: local PostGIS for offline dev only (docker compose)
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5433/plotpin

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Explore search — anonymous GET /buildings in-memory cache (ms / max entries)
EXPLORE_SEARCH_CACHE_TTL_MS=30000
EXPLORE_SEARCH_CACHE_MAX_ENTRIES=256

# ─── Google Maps ────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
NEXT_PUBLIC_GOOGLE_MAP_ID=your-map-id

# ─── Payments (Sprint 5B: Flutterwave + Lemon Squeezy — see docs/PAYMENTS-STRATEGY.md)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_WEBHOOK_SECRET=your-flw-webhook-secret
LEMON_SQUEEZY_API_KEY=your-ls-api-key
LEMON_SQUEEZY_WEBHOOK_SECRET=your-ls-webhook-secret
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_VARIANT_ID=your-unlock-variant-id

# Dev only — simulates paid unlock without checkout (keep 1 in local .env)
ALLOW_DEV_UNLOCK=1

# Optional — deferred until US LLC exists
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Pricing (UGX defaults) ─────────────────────────────────
TENANT_UNLOCK_FEE_UGX=20000
LANDLORD_LISTING_FEE_UGX=30000

# ─── Dev Verification  Code (optional)───────────────────────────────────────────────
AUTH_OTP_DEV_CODE=999999

# ─── Postmark (verify domain in Postmark; Zoho receives Reply-To) ───
POSTMARK_SERVER_TOKEN=your-server-token
POSTMARK_FROM_EMAIL="PlotPin <noreply@plotpin.net>"
POSTMARK_REPLY_TO_EMAIL=support@plotpin.net
