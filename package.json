{
  "name": "plotpin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "yarn workspace @plotpin/web dev",
    "dev:api": "yarn workspace @plotpin/api dev",
    "build": "turbo run build",
    "build:web": "yarn workspace @plotpin/web build",
    "build:api": "yarn workspace @plotpin/api build",
    "lint": "turbo run lint",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed:dev:clean": "node scripts/seed-dev-clean.mjs"
  },
  "devDependencies": {
    "pg": "^8.16.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "packageManager": "yarn@1.22.22"
}
